{
  "name": "labview-vi-support",
  "displayName": "LabVIEW VI Support",
  "description": "LabVIEW VI file support for Visual Studio Code",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "NEVSTOP-LAB",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/NEVSTOP-LAB/vsc-labview-vi-support.git"
  },
  "bugs": {
    "url": "https://github.com/NEVSTOP-LAB/vsc-labview-vi-support/issues"
  },
  "homepage": "https://github.com/NEVSTOP-LAB/vsc-labview-vi-support#readme",
  "keywords": [
    "labview",
    "vi",
    "lvlib",
    "ctl",
    "virtual instrument",
    "ni",
    "national instruments"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "labview-vi-support.helloWorld",
        "title": "%commands.helloWorld%",
        "category": "%commands.category%"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run generate-icon && npm run package",
    "generate-icon": "node scripts/generate-icon.js",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "pretest:unit": "npm run compile-tests",
    "test:unit": "mocha --ui tdd --reporter spec \"out/test/unit/**/*.test.js\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
